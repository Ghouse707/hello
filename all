import numpy as np

# Input data
x = np.array([[2,9],
              [1,5],
              [3,6]], dtype=float)

# Output data
y = np.array([[92],
              [86],
              [89]], dtype=float)

# Normalize values
x = x / np.max(x, axis=0)
y = y / 100

# Sigmoid function
def sigmoid(x):
    return 1 / (1 + np.exp(-x))

# Derivative of sigmoid
def derivative_sigmoid(x):
    return x * (1 - x)

# Random weights
wh = np.random.rand(2,3)
wout = np.random.rand(3,1)

# Training
for i in range(5000):

    # Forward propagation
    hidden = sigmoid(np.dot(x, wh))
    output = sigmoid(np.dot(hidden, wout))

    # Error
    EO = y - output

    # Backpropagation
    d_output = EO * derivative_sigmoid(output)
    d_hidden = d_output.dot(wout.T) * derivative_sigmoid(hidden)

    # Update weights
    wout += hidden.T.dot(d_output) * 0.1
    wh += x.T.dot(d_hidden) * 0.1

    # Print loss every 1000 epochs
    if i % 1000 == 0:
        mse = np.mean(np.square(y - output))
        print(f"Epoch {i}, Loss: {mse}")

# Final result
print("Final Output:")
print(output)





