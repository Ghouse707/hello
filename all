import random
import matplotlib.pyplot as plt

# Fitness function
def fitness(x):
    return x * x

# Initial population
pop = [random.randint(-5, 5) for i in range(10)]

# Store fitness history
history = []

# Genetic Algorithm loop
for i in range(20):

    # Sort population based on fitness
    pop.sort(key=fitness, reverse=True)

    # Store best fitness
    history.append(fitness(pop[0]))

    # Select top 5 parents
    parents = pop[:5]

    # Create new population
    pop = parents.copy()

    # Generate children
    while len(pop) < 10:

        # Select two parents
        p1 = random.choice(parents)
        p2 = random.choice(parents)

        # Crossover operation
        child = (p1 + p2) / 2

        # Add child to population
        pop.append(child)

# Final result
print("Best Solution =", pop[0])
print("Best Fitness =", fitness(pop[0]))

# Plot graph
plt.plot(history)
plt.xlabel("Generation")
plt.ylabel("Best Fitness")
plt.title("Genetic Algorithm Optimization")
plt.show()


