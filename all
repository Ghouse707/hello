# Dataset
dataset = [
    {"Age": 20, "Income": 25000, "Buy": "No"},
    {"Age": 22, "Income": 30000, "Buy": "No"},
    {"Age": 25, "Income": 50000, "Buy": "Yes"},
    {"Age": 28, "Income": 55000, "Buy": "Yes"},
    {"Age": 30, "Income": 60000, "Buy": "Yes"},
    {"Age": 35, "Income": 40000, "Buy": "No"},
    {"Age": 40, "Income": 70000, "Buy": "Yes"},
    {"Age": 45, "Income": 80000, "Buy": "Yes"}
]

# Learn rule
def learn_rule(data):
    for d in data:
        if d["Buy"] == "Yes":
            return lambda x: (25 <= x["Age"] <= 45) and (x["Income"] > 40000)

# Test rule
def test_rule(data, rule):

    predictions = []
    tp = fp = tn = fn = 0

    for d in data:

        pred = "Yes" if rule(d) else "No"
        predictions.append(pred)

        actual = d["Buy"]

        if pred == "Yes" and actual == "Yes":
            tp += 1
        elif pred == "Yes" and actual == "No":
            fp += 1
        elif pred == "No" and actual == "No":
            tn += 1
        else:
            fn += 1

    accuracy = ((tp + tn) / len(data)) * 100

    return predictions, accuracy, tp, fp, tn, fn


# Run
rule = learn_rule(dataset)

predictions, accuracy, tp, fp, tn, fn = test_rule(dataset, rule)

print("Predictions:", predictions)

print("\nAccuracy:", accuracy, "%")

print("\nTrue Positives:", tp)
print("False Positives:", fp)
print("True Negatives:", tn)
print("False Negatives:", fn)
print("Accuracy:", accuracy, "%")

